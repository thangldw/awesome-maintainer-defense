{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thangldw/awesome-maintainer-defense/audits.schema.json",
  "title": "Awesome Maintainer Defense evidence audit",
  "type": "object",
  "required": ["schema_version", "verified_on", "methodology", "audits"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "verified_on": {"type": "string", "format": "date"},
    "methodology": {"type": "object"},
    "audits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "repository", "repo_snapshot", "deployment", "default_mode", "automation_impact", "maximum_effects", "data_boundaries", "access", "limitations", "evidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "repository": {"type": "string", "pattern": "^[^/]+/[^/]+$"},
          "repo_snapshot": {
            "type": "object",
            "required": ["archived", "pushed_at", "license_detected"],
            "properties": {
              "archived": {"type": "boolean"},
              "pushed_at": {"type": "string", "format": "date-time"},
              "license_detected": {"type": "string"}
            }
          },
          "deployment": {"type": "string", "minLength": 3},
          "default_mode": {"type": "string", "minLength": 10},
          "automation_impact": {"enum": ["low", "medium", "high"]},
          "maximum_effects": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "data_boundaries": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "access": {"type": "string", "minLength": 3},
          "limitations": {"type": "string", "minLength": 40},
          "evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "format": "uri", "pattern": "^https://"}}
        }
      }
    }
  }
}
